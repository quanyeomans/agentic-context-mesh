# docker/.env — copy to docker/.env and fill in values
# Required for vault-agent to fetch secrets from Azure Key Vault
# Never commit the real .env file to git

# ── Azure Key Vault ───────────────────────────────────────────────────────────
# Key Vault name (e.g. your-key-vault-name). The vault-agent sidecar fetches all
# required Azure OpenAI and Neo4j secrets from this vault at startup.
KAIRIX_KV_NAME=your-key-vault-name

# ── Azure Auth ────────────────────────────────────────────────────────────────
# On Azure VMs with Managed Identity enabled, leave these blank — the sidecar
# will authenticate automatically via DefaultAzureCredential.
# For local dev or non-Azure hosts, provide a service principal:
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# ── Paths (host paths mounted into containers) ────────────────────────────────
KAIRIX_VAULT_ROOT=/data/obsidian-vault
KAIRIX_WORKSPACE_ROOT=/data/workspaces
KAIRIX_DATA_DIR=/data/kairix

# ── Neo4j ─────────────────────────────────────────────────────────────────────
# URI uses the service name 'neo4j' when running in compose
KAIRIX_NEO4J_URI=bolt://neo4j:7687
KAIRIX_NEO4J_USER=neo4j
# Password used by the neo4j container and kairix client.
# On the VM this is injected by the vault-agent from KV secret kairix-neo4j-password.
# For local docker-compose, set it here so the neo4j container can be initialised.
KAIRIX_NEO4J_PASSWORD=changeme-local-dev-only

# ── Optional ──────────────────────────────────────────────────────────────────
# How often vault-agent refreshes secrets from KV (default: 3600s / 1 hour)
REFRESH_INTERVAL_SECONDS=3600
